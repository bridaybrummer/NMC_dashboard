# NMC Data Summary, `r reporting_date_month_year` {.unnumbered}

```{r nmc-summary-prep}
#| include: false

df1 %>%
  ungroup() %>%
  select(case_type, nmccategories) %>%
  mutate(nmccategories = factor(nmccategories, levels = c(1, 2, 3))) %>%
  tbl_summary(
    by      = case_type,
    missing = "ifany",
    label   = list(nmccategories ~ "")
  ) %>%
  modify_header(
    all_stat_cols() ~ "**{level}**, \n n = {scales::number(n)}",
    label = "**NMC Category**"
  ) %>%
  add_overall() %>%
  modify_footnote(update = everything() ~ NA) ->
  table_summary

table_summary[["table_body"]][["label"]] <- c("", "Category 1", "Category 2", "Category 3")
len <- nrow(table_summary[["table_body"]])
table_summary[["table_body"]] <- table_summary[["table_body"]][2:len, ]

cat1 <- table_summary[["table_body"]][["stat_0"]][
  grep("^category 1", table_summary[["table_body"]][["label"]], ignore.case = TRUE)
] %>% as.character()

cat2 <- table_summary[["table_body"]][["stat_0"]][
  grep("^category 2", table_summary[["table_body"]][["label"]], ignore.case = TRUE)
] %>% as.character()

cat3 <- table_summary[["table_body"]][["stat_0"]][
  grep("^category 3", table_summary[["table_body"]][["label"]], ignore.case = TRUE)
] %>% as.character()

back_captured <- df2 %>%
  select(prov_, condition) %>%
  tbl_summary(
    by        = prov_,
    statistic = all_categorical() ~ "{n}",
    label     = condition ~ "",
    sort      = list(everything() ~ "frequency")
  ) %>%
  modify_header(
    all_stat_cols() ~ "**{level}**, \n ({scales::number(n)})",
    label = "**Condition**"
  ) %>%
  modify_footnote(update = everything() ~ NA)

back_captured_overall <- df2 %>%
  select(condition) %>%
  tbl_summary(
    label = condition ~ "",
    sort  = list(everything() ~ "frequency")
  ) %>%
  modify_header(
    all_stat_cols() ~ "**Overall**, ({scales::number(n)})",
    label = "**Condition**"
  ) %>%
  modify_footnote(update = everything() ~ NA)

most_common_back_captured_condition <- back_captured_overall[["table_body"]][["label"]][2]
most_common_back_captured_number    <- back_captured_overall[["table_body"]][["stat_0"]][2] %>%
  as.character() %>% sub("\\s*\\(", ", ", .) %>% sub("\\)", "", .)
```

In `r reporting_date_month_year` the NMCSS received a total of
**`r format(nrow(df1), big.mark = " ")`** notifications.
Of these, `r cat1` were Category 1 notifications, `r cat2` were Category 2, and `r cat3` were Category 3.

## Category 1 Notifications {.unnumbered}

```{r cat1-notifications}
#| include: false
#| warnings: false

category_number <- 1
tbl_df2 <- df1 %>% filter(nmccategories == category_number) %>% setDT()

category_1 <- condition_df %>%
  filter(nmccategories %in% 1) %>% pull(condition) %>% sort()

tbl_province_cat1 <- tbl_df2 %>%
  select(prov_, condition) %>%
  mutate(condition = factor(condition, levels = sort(unique(tbl_df2$condition)))) %>%
  tbl_summary(
    by      = prov_,
    label   = condition ~ "",
    percent = "row"
  ) %>%
  add_overall() %>%
  modify_header(
    all_stat_cols() ~ "**{level}**, n = {scales::number(n)} ({style_percent(p)}%)",
    label = "**Category 1 Condition**"
  )

tbl_province_cat1_total <- tbl_df2 %>%
  select(condition) %>%
  mutate(condition = factor(condition, levels = sort(unique(tbl_df2$condition)))) %>%
  tbl_summary(percent = "column") %>%
  modify_header(label = "**Category 1 Condition**")

tbl_province_cat1_total[["table_body"]] %>%
  mutate(
    n = as.numeric(gsub("\\(.*", "", tbl_province_cat1_total[["table_body"]][["stat_0"]])),
    n_percent = as.numeric(gsub("[^0-9.]+", "", gsub(".*\\((.*?)%\\).*", "\\1",
                  tbl_province_cat1_total[["table_body"]][["stat_0"]]))),
    na.rm = TRUE
  ) %>%
  select(label, stat_0, n, n_percent) %>%
  na.omit() %>%
  arrange(-n) %>%
  as.data.table() -> tbl_province_cat1_totals_dt

max_cat1_disease   <- tbl_province_cat1_totals_dt$label[1]
max_cat1_disease_N <- tbl_province_cat1_totals_dt$stat_0[1]
```

The most commonly notified category 1 condition was
**`r max_cat1_disease`** (`r max_cat1_disease_N`).

```{r tbl-cat1-province}
#| label: tbl-cat1-province
#| tbl-cap: !expr 'paste0("Category 1 notifications by province, South Africa; ", reporting_date_month_year)'

tbl_province_cat1 %>%
  as_flex_table() %>%
  theme_zebra() %>%
  bg(bg = "#A5CA64", part = "header") %>%
  flextable::color(color = "white", part = "header") %>%
  fontsize(size = 7, part = "all") %>%
  flextable::set_table_properties(layout = "autofit", width = 1)
```

## Category 2 Notifications {.unnumbered}

Category 2 conditions must be notified within 7 days of diagnosis.

```{r cat2-prep}
#| include: false

category_number <- 2
tbl_df2 <- df1 %>% filter(nmccategories == category_number) %>% setDT()

conditions_category <- condition_df %>%
  filter(nmccategories %in% category_number) %>%
  select(condition) %>%
  mutate(condition = case_when(
    condition == "Cholera"    ~ "Cholera §",
    condition == "Diphtheria" ~ "Diphtheria *",
    grepl("tuberculosis", ignore.case = TRUE, condition) ~ paste0(condition, "*"),
    .default = condition
  )) %>%
  pull()

tbl_province_cat2 <- tbl_df2 %>%
  select(prov_, condition) %>%
  mutate(condition = case_when(
    condition == "Cholera"    ~ "Cholera §",
    condition == "Diphtheria" ~ "Diphtheria *",
    grepl("tuberculosis", ignore.case = TRUE, condition) ~ paste0(condition, "*"),
    TRUE ~ condition
  )) %>%
  mutate(condition = factor(condition, levels = conditions_category)) %>%
  tbl_summary(
    by    = prov_,
    label = condition ~ ""
  ) %>%
  add_overall() %>%
  modify_header(
    all_stat_cols() ~ "**{level}**, n = {scales::number(n)} ({style_percent(p)}%)",
    label = "**Category 2 Condition**"
  )

tbl_province_cat2[["table_body"]] %>%
  mutate(
    label = gsub("\\*", "", label),
    n = as.numeric(gsub(" ", "", gsub("\\(.*", "", tbl_province_cat2[["table_body"]][["stat_0"]]))),
    n_percent = as.numeric(gsub("[^0-9.]+", "", gsub(".*\\((.*?)%\\).*", "\\1",
                  tbl_province_cat2[["table_body"]][["stat_0"]]))),
    na.rm = TRUE
  ) %>%
  select(label, stat_0, n, n_percent) %>%
  na.omit() %>%
  arrange(-n) %>%
  as.data.table() -> tbl_province_cat2_total_conditions

max_cat2_disease   <- tbl_province_cat2_total_conditions$label[1]
max_cat2_disease_N <- tbl_province_cat2_total_conditions$stat_0[1]
```

The most common Category 2 condition was **`r max_cat2_disease`** (`r max_cat2_disease_N`).

```{r tbl-cat2-province}
#| label: tbl-cat2-province
#| tbl-cap: !expr 'paste0("Category 2 notifications by province, South Africa; ", reporting_date_month_year)'

tbl_province_cat2 %>%
  as_flex_table() %>%
  theme_zebra() %>%
  bg(bg = "#A5CA64", part = "header") %>%
  flextable::color(color = "white", part = "header") %>%
  fontsize(size = 7, part = "all") %>%
  flextable::set_table_properties(layout = "autofit", width = 1)
```

