# NMC App Statistics {.unnumbered}

## Notification Types and Merging {.unnumbered}

```{r app-notification-types}
#| label: fig-notification-types
#| fig-cap: !expr 'paste0("Notification source trends, South Africa; January 2022–", reporting_date_month_year)'

new_master1 %>%
  mutate(
    case_source2 = case_when(
      grepl("iOS|Android", case_source)       ~ "App (iOS/Android)",
      grepl("Web",         case_source)       ~ "App (Web)",
      grepl("Paper",       case_source)       ~ "Paper-based",
      grepl("micro",  ignore.case = TRUE, case_source) ~ "SDW/Microstrategy",
      TRUE ~ case_source
    ),
    ym = as.Date(floor_date(as_date(notification_date), "month"))
  ) %>%
  count(ym, case_source2) %>%
  ggplot(aes(x = ym, y = n, colour = case_source2, group = case_source2)) +
  geom_line(linewidth = 0.8) +
  geom_point(size = 1.5) +
  scale_x_date(date_breaks = "3 months", date_labels = "%b %Y") +
  scale_y_continuous(labels = scales::comma) +
  labs(
    x      = NULL,
    y      = "Number of notifications",
    colour = "Notification source",
    title  = "Monthly notifications by case source"
  ) +
  as_excel() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))
```

---

# Data Quality {.unnumbered}

## Completeness {.unnumbered}

```{r completeness-prep}
#| include: false

vars_completeness <- c(
  "folder_no", "patient_name", "patient_surname",
  "symptom_date", "diagnosis_date", "patient_vital_status"
)

missing_df <- df1 %>%
  mutate(across(all_of(vars_completeness),
    .fns = ~ ifelse(is.na(.) | grepl("Unknown", ignore.case = TRUE, .), 0, 1)
  )) %>%
  mutate(
    case_source1 = factor(case_when(
      grepl("iOS|Web|Android", case_source)           ~ "App",
      grepl("Paper",           case_source)           ~ "Paper-based",
      grepl("micro", ignore.case = TRUE, case_source) ~ "Laboratory notification",
      TRUE ~ "Other"
    ))
  )
```

```{r fig-completeness}
#| label: fig-completeness
#| fig-cap: !expr 'paste0("Completeness of key variables by notification source, ", reporting_date_month_year)'

missing_df %>%
  select(case_source1, all_of(vars_completeness)) %>%
  pivot_longer(-case_source1, names_to = "variable", values_to = "present") %>%
  group_by(case_source1, variable) %>%
  summarise(pct_complete = mean(present, na.rm = TRUE) * 100, .groups = "drop") %>%
  ggplot(aes(x = variable, y = pct_complete, fill = case_source1)) +
  geom_col(position = "dodge") +
  scale_y_continuous(limits = c(0, 100), labels = function(x) paste0(x, "%")) +
  scale_fill_brewer(palette = "Set2") +
  labs(
    x    = "Variable",
    y    = "% Complete",
    fill = "Notification source",
    title = "Field completeness by notification source"
  ) +
  as_excel() +
  theme(axis.text.x = element_text(angle = 35, hjust = 1))
```

## ID Number Completeness {.unnumbered}

```{r id-completeness}
#| label: fig-id-completeness
#| fig-cap: !expr 'paste0("ID number completeness by province, ", reporting_date_month_year)'

df1 %>%
  mutate(
    has_id = !is.na(folder_no) & nchar(trimws(as.character(folder_no))) == 13
  ) %>%
  group_by(prov_) %>%
  summarise(pct_id = mean(has_id, na.rm = TRUE) * 100, n = n(), .groups = "drop") %>%
  ggplot(aes(x = reorder(prov_, pct_id), y = pct_id)) +
  geom_col(fill = "#A5CA64") +
  geom_text(aes(label = paste0(round(pct_id, 1), "%")), hjust = -0.1, size = 3) +
  scale_y_continuous(limits = c(0, 110), labels = function(x) paste0(x, "%")) +
  coord_flip() +
  labs(x = "Province", y = "% with valid ID (13 digits)", title = "ID number completeness") +
  as_excel()
```

## Timeliness {.unnumbered}

```{r timeliness-prep}
#| include: false

timeliness_df <- df1 %>%
  mutate(
    time_to_notification = as.numeric(time_to_notification),
    nmccategories        = factor(paste0("Category ", nmccategories), levels = c("Category 1", "Category 2", "Category 3"))
  ) %>%
  filter(!is.na(time_to_notification))
```

```{r tbl-timeliness}
#| label: tbl-timeliness
#| tbl-cap: !expr 'paste0("Timeliness of notifications (days from diagnosis to notification), ", reporting_date_month_year)'

timeliness_df %>%
  select(nmccategories, time_to_notification) %>%
  tbl_summary(
    by     = nmccategories,
    label  = list(time_to_notification ~ "Days to notification"),
    digits = list(everything() ~ c(0, 0))
  ) %>%
  modify_footnote(update = everything() ~ NA) %>%
  as_flex_table() %>%
  theme_zebra() %>%
  bg(bg = "#A5CA64", part = "header") %>%
  flextable::color(color = "white", part = "header") %>%
  flextable::set_table_properties(layout = "autofit", width = 1)
```

---

# Conclusion {.unnumbered}

The majority of notifications were clinical notifications.
Patients who are hospitalised with a category 1 condition and notified still have poor completeness
of the hospital form, with the majority of notifications only having symptoms completed.
ID numbers are poorly completed in notifications from SDW.

# Recommendations {.unnumbered}

-   We recommend that clinicians complete all patient clinical and demographic details to improve hospital form completeness.
-   We strongly recommend complete ID number capture in the SDW system to improve data quality and the ability for the NMCSS to merge clinical and laboratory notifications.
-   Feedback and suggestions are welcome at **brianb\@nicd.ac.za** and **matimbam\@nicd.ac.za**.

---

# Appendices {.unnumbered}

## Appendix 1: Back-Captured Clinical Notifications {.unnumbered}

```{r appendix1}
#| label: tbl-backcapture
#| tbl-cap: !expr 'paste0("Back-captured and delayed notifications by condition and case source, ", reporting_date_month_year)'

df2 %>%
  select(case_source, condition) %>%
  mutate(case_source = ifelse(case_source == "Microstrategy/SDW", "SDW", case_source)) %>%
  tbl_summary(
    by        = case_source,
    label     = condition ~ "",
    statistic = everything() ~ "{n}",
    sort      = list(everything() ~ "frequency")
  ) %>%
  modify_header(
    label = "",
    all_stat_cols() ~ "**{level}**, \n ({scales::number(n)})"
  ) %>%
  modify_footnote(update = everything() ~ NA) %>%
  as_flex_table() %>%
  theme_zebra() %>%
  bg(bg = "#A5CA64", part = "header") %>%
  flextable::color(color = "white", part = "header") %>%
  fontsize(size = 7, part = "all") %>%
  flextable::set_table_properties(layout = "autofit", width = 1)
```

## Appendix 2: Summary of NMCSS Data Flow {.unnumbered}

The NMCSS receives notifications from:

1.  **NMC App** — web, iOS, Android (clinical and laboratory notifications)
2.  **Paper forms** — submitted by facilities and captured into the system
3.  **SDW/Microstrategy** — laboratory notifications drawn from the NHLS system

Notifications are merged where clinical and laboratory notifications relate to the same case.

## Appendix 3: NMC Categories and Case Classification {.unnumbered}

| Category | Notification period | Description |
|---|---|---|
| Category 1 | Within 24 hours | Immediately notifiable; notify on clinical suspicion |
| Category 2 | Within 7 days   | Routine surveillance; notify after diagnosis |
| Category 3 | Within 7 days   | Outbreak-prone; aggregate reporting |
| Category 4 | Excluded from this report | |

: {.striped tbl-colwidths="[15,20,65]"}

