---
title: "NOTIFIABLE MEDICAL CONDITIONS SURVEILLANCE SYSTEM"
author: "The National Institute for Communicable Diseases"
date: today
params:
  reporting_month: "2025-05-01"   # ← set to the 1st of the target month (YYYY-MM-01)
format:
  html:
    toc: true
    toc-depth: 3
    toc-float: true
    number-sections: false
    embed-resources: true          # single self-contained HTML file
    theme: cosmo
    css: "../styles.css"
  docx:
    reference-doc: "../NMC_reports_scripts/extras/weekly_IDSR_V2_template.docx"
    reference-location: "section"
    number-sections: true
    fig-caption: true
    toc: true
    toc-depth: 3
execute:
  echo: false
  warning: false
  message: false
  error: false
---

```{r setup}
#| label: setup
#| include: false

# ── Package management ─────────────────────────────────────────────────────────
if (!requireNamespace("pacman", quietly = TRUE)) install.packages("pacman")

library(NMCleaner)
conflicts_prefer(dplyr::filter)
library(stringdist)
library(kableExtra)
library(data.table)
library(ragg)

# ── Global flextable settings ──────────────────────────────────────────────────
flextable::set_flextable_defaults(
  font.family  = "Century Gothic",
  font.size    = 8,
  header.font.size = 8,
  border.color = "black",
  padding      = 0.1
)

gtsummary::theme_gtsummary_language(
  language = "en", big.mark = " ", decimal.mark = "."
)

knitr::opts_chunk$set(
  ft.align  = "left",
  echo      = FALSE,
  warning   = FALSE,
  message   = FALSE,
  out.width = "100%",
  dev       = "ragg_png",
  dpi       = 300
)

# ── Helper: trim gtsummary header row ─────────────────────────────────────────
trim_tbl <- function(gt_summary_object) {
  n <- nrow(gt_summary_object$table_body)
  gt_summary_object$table_body <- gt_summary_object$table_body[2:n, ]
  gt_summary_object
}

# ── ggplot theme (matches report style) ───────────────────────────────────────
as_excel <- function() {
  theme_minimal() +
    theme(
      text             = element_text(family = "Arial", size = 10, color = "#333333"),
      panel.background = element_rect(fill = "#F8F8F8"),
      plot.background  = element_rect(fill = "#F8F8F8"),
      panel.grid       = element_line(color = "#DDDDDD"),
      legend.text      = element_text(family = "Arial", color = "#333333", size = 8),
      legend.title     = element_text(family = "Arial", color = "#333333", size = 10),
      plot.title       = element_text(family = "Arial", size = 10, color = "#666666"),
      plot.subtitle    = element_text(family = "Arial", size = 8,  color = "#666666"),
      plot.caption     = element_text(family = "Arial", size = 8,  color = "#666666"),
      legend.position  = "right",
      legend.direction = "vertical",
      legend.key       = element_blank(),
      axis.text.x      = element_text(angle = 30),
      axis.title       = element_text(size = 10, color = "#666666"),
      panel.grid.minor = element_blank(),
      axis.ticks       = element_line(linewidth = 0.15, color = "grey20"),
      legend.background = element_rect(fill = "#F8F8F8", linewidth = 0.25,
                                       linetype = "solid", colour = "grey50")
    )
}

# ── Load master dataset ────────────────────────────────────────────────────────
# Path is absolute so it works regardless of working directory.
new_master <- arrow::read_feather(
  "~/Desktop/SAFETP/CLA/NMC_database/master/new_master.feather"
)

new_master <- new_master %>%
  mutate(
    nmccategories = if_else(
      condition %in% "Agricultural or stock remedy poisoning", "1", nmccategories
    )
  )

exported_date <- new_master$export_date %>% as_date() %>% max()

# ── Set reporting period from params ──────────────────────────────────────────
reporting_date          <- as_date(params$reporting_month)
last_dat_reporting_month <- ceiling_date(reporting_date, "month") - days(1)

reporting_date_month_year <- format(reporting_date, "%B, %Y")
reporting_date_month      <- format(reporting_date, "%B")

# ── Filter master to the reporting month ──────────────────────────────────────
new_master <- new_master %>%
  mutate(across(c(nmccategories, case_type), as.factor)) 

new_master %>%
  dplyr::filter(notification_date < as_date(last_dat_reporting_month)) ->
  new_master1

reporting_yearmonth_grates <- last_dat_reporting_month %>% grates::as_yearmonth()

df <- new_master1 %>%
  dplyr::filter(Month_notification %in% reporting_yearmonth_grates) %>%
  mutate(reporting = 1) %>%
  dplyr::filter(!condition %in% "Leprosy") %>%
  dplyr::filter(!case_id %in% c("231005_4441991", "240126_46621391")) %>%
  mutate(condition = ifelse(condition == "Covid-19", "COVID-19", condition)) %>%
  dplyr::filter(
    !is.na(prov_),
    !condition %in% c("COVID-19", "Waterborne illness outbreak - undefined")
  ) %>%
  ungroup()

df1 <- df %>% dplyr::filter(back_capture_new %in% c("Current", "Delayed", "unknown"))
df2 <- df %>% dplyr::filter(!back_capture_new %in% c("Current", "Delayed", "unknown"))

# ── Source shared scripts ──────────────────────────────────────────────────────
# Use here::here() so the path resolves from the project root (anchored by .here)
# regardless of the working directory at render time.
source(here::here("NMC_reports_scripts", "scripts_and_functions", "context_table.R"))

flextable::set_flextable_defaults(
  font.family      = "Century Gothic",
  font.size        = 6,
  header.font.size = 6,
  border.color     = "black",
  padding          = 0.1
)
```

# Introduction {.unnumbered}

Data used in this report was drawn from the NMC-SS on **`r format(exported_date, "%d %B %Y")`**.
The most recent report should always be viewed and can be found at
[NMCSS surveillance reports](https://www.nicd.ac.za/nmc-overview/nmc-monthly-surveillance-report/).

The purpose of this report is to describe the number of notifications received by the Notifiable
Medical Conditions Surveillance System (NMCSS). The report is publicly available and can be used
by health professionals, researchers, the general public, or any other stakeholder.

Category 4 NMCs, COVID-19, and multi-system inflammatory syndrome (MIS-C) have been excluded from
this report. Where weeks are presented, the epiweek according to the CDC epiweeks are used.

## Highlights {.unnumbered}

```{r highlights-prep}
#| include: false

tbl_notifications <- df1 %>%
  select(nmccategories, time_to_notification) %>%
  mutate(time_to_notification = as.numeric(time_to_notification)) %>%
  tbl_summary(
    by     = nmccategories,
    label  = list(time_to_notification ~ "Time to Notification"),
    digits = list(everything() ~ c(0, 0))
  ) %>%
  modify_footnote(update = everything() ~ NA)

cat1_notif_time <- tbl_notifications[["table_body"]][["stat_1"]][[1]] %>% as.character()

nmc_url        <- "https://nmc.nicd.ac.za/Account/Login"
surveillance_url <- "https://www.nicd.ac.za/nmc-overview/nmc-monthly-surveillance-report/"
report_url     <- "https://www.nicd.ac.za/wp-content/uploads/2022/09/NMCSS-Data-Interpretation-Infographic-final2.pdf"
```

-   A total of **`r format(nrow(df), big.mark = " ")`** cases were notified in `r reporting_date_month_year` and most were category 2 conditions.
-   Category 1 cases were reported in a median (IQR) of **`r cat1_notif_time`** days.
-   The most common conditions notified were `r df1$condition %>% unique() %>% sort() %>% paste(collapse = ", ")`.

```{r tbl-highlights}
#| label: tbl-highlightsNotifications
#| tbl-cap: !expr 'paste0("Highlights of notifications reported to the NMC, in South Africa; January 2022–", reporting_date_month_year)'

df1 %>%
  select(nmccategories, case_type) %>%
  mutate(nmccategories = paste0("Category ", nmccategories)) %>%
  tbl_summary(
    by      = case_type,
    percent = "row",
    label   = list(nmccategories ~ "NMC Category")
  ) %>%
  modify_header(label = "") -> tbl_by_case_type

df1 %>%
  select(nmccategories, case_definition) %>%
  mutate(nmccategories = paste0("Category ", nmccategories)) %>%
  tbl_summary(
    by         = case_definition,
    percent    = "row",
    statistic  = list(all_categorical() ~ "{n}/{N} ({p}%)"),
    label      = list(nmccategories ~ "NMC Category")
  ) %>%
  gtsummary::modify_column_hide(stat_2) %>%
  modify_footnote_header(
    columns  = everything(),
    footnote = "n confirmed / N (proportion confirmed %)"
  ) -> tbl_of_confirmed

df1 %>%
  mutate(
    nmccategories  = paste0("Category ", nmccategories),
    case_definition = if_else(
      grepl("lab|rapid", ignore.case = TRUE, diagnosis_method), "Confirmed", case_definition
    )
  ) %>%
  select(nmccategories, case_definition) %>%
  tbl_summary(
    by         = case_definition,
    percent    = "row",
    label      = list(nmccategories ~ "NMC Category")
  ) %>%
  modify_header(label = "") %>%
  gtsummary::modify_column_hide(stat_2) %>%
  modify_footnote_header(
    columns  = everything(),
    footnote = "n confirmed / N (proportion confirmed %) — by reported diagnosis method"
  ) -> tbl_by_diagnosis_method

tbl_merge(
  tbls        = list(tbl_by_case_type, tbl_of_confirmed, tbl_by_diagnosis_method),
  tab_spanner = c("**Case Type**", "**Confirmed by Centre**", "**Reported by Diagnosis Method**")
) %>%
  as_flex_table() %>%
  theme_zebra() %>%
  bg(bg = "#A5CA64", part = "header") %>%
  flextable::color(color = "white", part = "header") %>%
  flextable::set_table_properties(layout = "autofit", width = 1)
```

---

# Category 1 Conditions {.unnumbered}

Category 1 conditions must be notified within 24 hours of diagnosis. A total of
**`r format(nrow(df1 %>% filter(nmccategories == 1)), big.mark = " ")`** category 1 conditions
were notified in `r reporting_date_month_year`. The majority were notified with a median (IQR)
time to notification of **`r cat1_notif_time`** days.

## NMC Reporting Application {.unnumbered}

-   [NMC Reporting App](`r nmc_url`) is available on both web and mobile platforms.
-   Use recommended browsers to access the NMC reporting App for notifications, searching of cases and reports.
-   Register if you have no NMC account; you can reset your password if you have not used the application in over 12 months.

```{r note-image}
#| fig-align: center
# Image path is relative to the project root (execute-dir: project)
if (file.exists("NMC_reports_scripts/images/NOTE.png")) {
  knitr::include_graphics("NMC_reports_scripts/images/NOTE.png")
}
```

## Current Notification Trends {.unnumbered}

Trends of notifications of selected conditions are presented below.

### Confirmed Notifications {.unnumbered}

#### Epitable {.unnumbered}

```{r tbl-epitable1}
#| label: tbl-epitable1
#| tbl-cap: !expr 'paste0("Confirmed notifications of selected category 1 conditions reported to the NMC, in South Africa; January 2022–", reporting_date_month_year)'

conflicts_prefer(dplyr::filter)

confirmed_new_master1 <- new_master1 %>%
  dplyr::filter(grepl("confirmed", ignore.case = TRUE, case_definition))

context_table(confirmed_new_master1, as_date(last_dat_reporting_month)) -> ft

df1 %>%
  group_by(epiweek, day) %>%
  summarise(n = n(), .groups = "drop") %>%
  group_by(epiweek) %>%
  summarise(n_days = n(), .groups = "drop") %>%
  filter(n_days >= 7) %>%
  pull(epiweek) %>%
  as.numeric() -> full_epiweeks

max_full_epiweek <- if (length(full_epiweeks) > 0) max(full_epiweeks) else 0

grey_column <- max_full_epiweek - df1$notification_date %>%
  as_date() %>% max() %>% as_epiweek() %>%
  gsub(".*W", "", .) %>% as.numeric() + 4

col_length             <- ft[[1]]$col_keys %>% length()
number_of_conditions   <- ft[[1]]$body[[1]]$label %>% length()
std_border             <- officer::fp_border(color = "black", width = 1)

ft[[1]] %>%
  autofit() %>%
  fontsize(size = 7, part = "all") %>%
  bg(j = (col_length - 5):col_length, bg = "grey90", part = "body") %>%
  theme_zebra() %>%
  bg(bg = "#A5CA64", part = "header") %>%
  flextable::color(color = "white", part = "header") %>%
  surround(j = (col_length - 5), border.left  = std_border, part = "body") %>%
  surround(j = col_length,        border.right = std_border, part = "body") %>%
  surround(i = 1,                 j = (col_length - 5):col_length, border.top    = std_border) %>%
  surround(i = number_of_conditions, j = (col_length - 5):col_length, border.bottom = std_border)
```

#### Trends Plot {.unnumbered}

```{r epicurve-confirmed-prep}
#| include: false

flextable::set_flextable_defaults(
  font.family = "Century Gothic", font.size = 8, header.font.size = 8,
  border.color = "black", padding = 0.1
)

current_year <- as.numeric(as_year(Sys.Date()))

df_epicurve_confirmed <- new_master1 %>%
  dplyr::filter(case_definition %in% "Confirmed") %>%
  dplyr::filter(nmccategories == 1) %>%
  epicurve_df(., date_index = "notification_date", grouping_vars = "condition")

df_epicurve_confirmed1 <- df_epicurve_confirmed %>%
  dplyr::filter(year %in% 2022:current_year) %>%
  mutate(year = factor(year, levels = 2022:current_year))

plot_confirmed <- df_epicurve_confirmed1 %>%
  dplyr::filter(condition %in% c(
    "Cholera", "Covid-19", "Diphtheria", "Malaria",
    "Measles", "Mpox", "Pertussis", "Rubella"
  )) %>%
  plot_epicurve_df(.,
    x_axis_option  = "epiweek",
    grouping_vars  = "condition",
    color_select   = "olivedrab"
  )
```

```{r fig-epicurve-confirmed}
#| label: fig-epicurve-confirmed
#| fig-cap: !expr 'paste0("Trend of weekly confirmed notifications for selected category 1 conditions, South Africa; January 2022–", reporting_date_month_year)'

plot_confirmed$plot
```

## All Category 1 Conditions at a Glance {.unnumbered}

```{r tbl-cat1-glance}
#| label: tbl-IDSR_snapshot
#| tbl-cap: !expr 'paste0("Confirmed notifications (by diagnosis method) for category 1 conditions notified during ", reporting_date_month_year)'

category_1 <- condition_df %>%
  filter(nmccategories %in% 1) %>%
  pull(condition) %>%
  sort()

df1 %>%
  filter(nmccategories == 1) %>%
  mutate(
    condition = factor(condition, levels = category_1),
    case_definition = factor(
      if_else(grepl("lab|rapid", ignore.case = TRUE, diagnosis_method), "Confirmed", case_definition),
      levels = c("Suspected", "Confirmed")
    )
  ) %>%
  dplyr::select(condition, case_definition) %>%
  tbl_summary(
    by        = case_definition,
    percent   = "row",
    statistic = list(all_categorical() ~ "{n}/{N} ({p})%")
  ) %>%
  modify_header(stat_2 = "**Category 1**") %>%
  trim_tbl() %>%
  modify_column_hide(stat_1) %>%
  modify_footnote(update = everything() ~ NA) %>%
  modify_footnote(all_stat_cols() ~ "n confirmed / N notified (proportion confirmed %)") ->
  cat_1_glance

ft_glance <- cat_1_glance %>%
  as_flex_table() %>%
  fontsize(size = 9, part = "header") %>%
  flextable::set_table_properties(layout = "autofit", width = 0.99)

to_bold <- which(!grepl("0\\/", ignore.case = TRUE, cat_1_glance$table_body$stat_2))

bold(ft_glance, i = to_bold, j = 1) %>%
  bg(i = to_bold, bg = "grey90", part = "body") %>%
  bg(j = 1:2, bg = "#A5CA64", part = "header") %>%
  flextable::color(part = "header", color = "white")
```

